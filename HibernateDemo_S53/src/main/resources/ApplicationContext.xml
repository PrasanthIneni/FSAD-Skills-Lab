<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans-3.1.xsd
           http://www.springframework.org/schema/context
           http://www.springframework.org/schema/context/spring-context-3.1.xsd">
           

<bean id="student1" class="DemoOnSpring.DemoOnSpringS53.Student">
<constructor-arg value = "1" type = "int"></constructor-arg>
<constructor-arg value = "Dhanush" type = "String"></constructor-arg>
</bean>
           
           
           
<bean id="c1" class="DemoOnSpring.DemoOnSpringS53.College">
<property name = "cname" value = "klu"></property>
<property name = "stud" ref="student1"></property>
</bean>           
           
               
</beans>
<bean id ="engine1Bean" class="DemoOnSpring.DemoOnSpringS53.Engine" >  
<constructor-arg value ="Petrol" type = "String"/>
 </bean>
 <!--  Create  a Bean for car class  -->
 <bean id="car1Bean" class="DemoOnSpring.DemoOnSpring_S53.Car">
 <constructer-arg ref="engine1Bean" //>
 </bean>